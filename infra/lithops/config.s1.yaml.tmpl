lithops:
  backend: aws_lambda
  storage: aws_s3
  log_level: INFO

aws:
  region: us-west-2

aws_lambda:
  execution_role: ${EXECUTION_ROLE_ARN}
  region: us-west-2
  architecture: x86_64
  namespace: ttc-dev
  max_workers: 30
  runtime_memory: 4096
  user_tags:
    name: "wri:project"
    value: "GRI-ttc"

aws_s3:
  region: us-west-2
  storage_bucket: ${STATE_BUCKET_USW2}
